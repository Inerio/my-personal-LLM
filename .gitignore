# ============================================
# Gustave Code — .gitignore
# ============================================

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
*.pyo
*.pyd
dist/
build/
.eggs/
*.whl
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
venv/
env/
.venv/
.env.local

# ---------- Node / React ----------
node_modules/
frontend/node_modules/
frontend/build/
frontend/dist/
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------- Environment ----------
# Real .env with secrets — NEVER commit
.env
# Keep .env.example (template)

# ---------- Data / Databases ----------
# SQLite databases and WAL files
*.db
*.db-shm
*.db-wal
*.db-journal
backend/data/
data/

# ---------- Test / Debug scripts ----------
test_*.py

# ---------- IDE / Editors ----------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ---------- OS ----------
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---------- Docker ----------
docker-compose.override.yml

# ---------- Logs ----------
*.log
logs/

# ---------- Claude Code ----------
.claude/
